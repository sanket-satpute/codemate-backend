# ==========================================
# CodeMate AI Backend Environment Variables
# ==========================================

# Profile selection
SPRING_PROFILES_ACTIVE=dev

# 1. Database & Security
# Local example:
MONGODB_URI=mongodb://localhost:27017/codescope
# Production alternative:
# MONGODB_PASSWORD=your_mongodb_password
# If MONGODB_URI is omitted in prod, the app falls back to the hosted Atlas template in application-prod.yml.
JWT_SECRET=your-secure-base64-encoded-secret-key-that-is-at-least-256-bits
FRONTEND_ORIGIN=http://localhost:4200

# 2. AI Routing Credentials (Required)
GITHUB_AI_TOKEN=your_github_models_key_here
GEMINI_AI_TOKEN=your_gemini_api_key_here
GROQ_AI_TOKEN=your_groq_api_key_here
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# 3. Cloudinary Configuration (Required for file/image uploads)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# 4. Production tuning flags
APP_REDIS_ENABLED=false
PROJECT_ID_BACKFILL_ENABLED=false

# Optional: Redis (only needed when APP_REDIS_ENABLED=true)
REDIS_URL=redis://default:your_redis_password@localhost:6379

# Optional: Local Ollama for development only
OLLAMA_BASE_URL=http://localhost:11434
